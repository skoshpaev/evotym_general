{
    "name": "skoshpaev/evotym-shared-bundle",
    "description": "Shared Symfony bundle for Evotym services",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "doctrine/orm": "^3.0",
        "symfony/config": "^6.4",
        "symfony/dependency-injection": "^6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/http-kernel": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "Evotym\\SharedBundle\\": "src/"
        }
    },
    "extra": {
        "symfony": {
            "bundle": "Evotym\\SharedBundle\\EvotymSharedBundle"
        }
    }
}
